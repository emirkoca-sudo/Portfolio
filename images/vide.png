    var add_feedback_form_attachments_current = 0;
    var add_feedback_form_attachments_newrefinput;
    var add_feedback_form_attachments_newref;
    var add_feedback_form_attachments_accept = "";

    function add_feedback_form_attachments_new() {
        add_feedback_form_attachments_current++;
        var id = 'add_feedback_form_attachments_files_' + add_feedback_form_attachments_current;
        add_feedback_form_attachments_newlabel = jQuery('<label>', {'for': id, 'class': 'visually-hidden'}).append(jQuery('#add_feedback_form_attachments_files_label').html());
        add_feedback_form_attachments_newrefinput = jQuery('<input>', {'type': 'file', 'id': id, 'name': id, 'class': 'file', 'accept': add_feedback_form_attachments_accept });
        add_feedback_form_attachments_newmaxsize = jQuery('<span>', {'id': id, 'class': 'file-description text-small text-midtone'}).append(jQuery('#add_feedback_form_attachments_files_maxsize').html());

        var add_feedback_form_attachments_newref = jQuery('<div>', {'class': 'file-wrapper'}).append(add_feedback_form_attachments_newlabel, add_feedback_form_attachments_newrefinput, add_feedback_form_attachments_newmaxsize);

        jQuery('#add_feedback_form_attachments_list').append(add_feedback_form_attachments_newref);

        add_feedback_form_attachments_newrefinput.trigger("focus");
    }
</script>
