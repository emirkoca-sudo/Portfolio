        + ",img[id|class|longdesc|style|usemap|src|border|alt=|title|hspace|vspace|width|height|align|role|aria-*]"
        + ",iframe[src|width|height|name|scrolling|frameborder|allow|allowfullscreen|webkitallowfullscreen|mozallowfullscreen|longdesc|marginheight|marginwidth|align|title|class|type|style]"
        + ",a[id|class|title|href|name|target|style]"
        + ",button[id|class|title]";

    var fontFormats = 'Andale Mono=andale mono,times;Arial=arial,helvetica,sans-serif;Arial Black=arial black,avant garde;Book Antiqua=book antiqua,palatino;Comic Sans MS=comic sans ms,sans-serif;Courier New=courier new,courier;Georgia=georgia,palatino;Helvetica=helvetica;Impact=impact,chicago;Open Sans=Open Sans;Symbol=symbol;Tahoma=tahoma,arial,helvetica,sans-serif;Terminal=terminal,monaco;Times New Roman=times new roman,times;Trebuchet MS=trebuchet ms,geneva;Verdana=verdana,geneva;Webdings=webdings;Wingdings=wingdings,zapf dingbats;';

    /**
     * Calculate an upper limit to the allowable editor height.
     *
     * The ideal limit varies depending on the circumstances, as some
     * editors are within the main content, while others are in modal
     * windows which overlay the main content, and hence are not subject
     * to fixed header/message areas.
     *
     * @param {Editor} aed - tinymce.js active editor object.
     * @returns {number} The calculated height limit.
     */
    let resizeLimit = function (aed) {
        if (aed) {
            let modal = aed.container.closest('.modal-body');
            if (modal && modal.clientHeight) {
                return Math.min(modal.clientHeight, window.innerHeight);
            }
        }
        // Otherwise we should be dealing with the main content.
        let main = document.getElementsByClassName('main-content');
        if (main.length && main[0].clientHeight) {
            if (main[0].clientHeight < window.innerHeight) {
                return main[0].clientHeight;
            }
        }
        // Fall back to the window.innerHeight minus messages+header.
        let heightLimit = window.innerHeight;
        let messages = document.getElementsByClassName('site-messages');
        let header = document.getElementsByTagName('header');
        if (messages.length && messages[0].clientHeight) {
            heightLimit -= messages[0].clientHeight;
        }
        if (header.length && header[0].clientHeight) {
            heightLimit -= header[0].clientHeight;
        }
        return heightLimit;
    }

    /**
     * Update the 'max_height' value for the 'autoresize' plugin to prevent the editor
     * from resizing beyond the viewport and ensure the toolbar remains visible
     *
     * When the 'autoresize' plugin is active, the 'max_height' setting controls when
     * the scrollbar appears and disappears. If the editor's height is constrained by
     * CSS or other means, the 'max_height' must align with these constraints to avoid
     * inconsistent scrollbar behavior, particularly when only part of the content is visible.
     *
     * To support responsive design and ensure the scrollbar appears appropriately,
     * it's crucial to maintain a suitable 'max_height' value.
     *
     * @param {Editor} aed - tinymce.js active editor object.
     */
    let resizeCallback = function (aed) {
        // Start by considering the editor's parent's height (e.g., for block editing).
        let newHeight = aed.settings.max_height;

        // Check if the editor container has a positioned ancestor with a fixed height.
        //
        // Start with the offsetParent (positioned ancestor) element, which may
        // have a fixed height (e.g. this is true for block editing).
        if (aed.container && aed.container.offsetParent) {
            let parentBounds = aed.container.offsetParent.getBoundingClientRect();
            if (parentBounds.height) {
                newHeight = parentBounds.height;
            }
        }

        // Apply an absolute limit on the editor height if specified.
        //
        // The offsetParent may not have a height restriction, so we apply an
        // absolute limit (which is re-calculated whenever the window itself is
        // resized; see the 'ResizeWindow' handler).
        if (aed.settings.max_height_limit) {
            newHeight = Math.min(newHeight, aed.settings.max_height_limit);
        }

        // Ensure the 'max_height' is not smaller than the 'min_height' to avoid unusable editor.
        //
        // Check if the editor container has a positioned ancestor with a fixed height.
        // so don't allow the former to ever be smaller than the latter,
        // otherwise the editor could become unusable.
        aed.settings.max_height = Math.max(newHeight, aed.settings.min_height);
    }

    let tinyMCEInitConfig = {
            theme: "silver",
    browser_spellcheck: true,
    contextmenu: false,
    plugins: "quickbars,tooltoggle,autoresize,fullscreen,visualblocks,wordcount,link,lists,imagebrowser,table,emoticons,paste,code,fullscreen,directionality,searchreplace,nonbreaking,charmap,mathslate,anchor",
    // default: 'fullscreen | undo redo | styleselect | bold italic | alignleft aligncenter alignright alignjustify | outdent indent',
    toolbar1: "toolbar_toggle | imagebrowser | table | fullscreen | undo redo | formatselect | bold italic | bullist numlist | link unlink ",
    toolbar2: " underline strikethrough subscript superscript | alignleft aligncenter alignright alignjustify | outdent indent | forecolor backcolor | ltr rtl",
    toolbar3: "fontselect | fontsizeselect | emoticons nonbreaking charmap mathslate  | removeformat pastetext | anchor | code",
    menubar: false,
    // Stop the ability to copy/paste an image in
    paste_data_images: true,
    paste_preprocess: (editor, args) => {
        // Handle any image 'src' starting with 'blob:' or 'data:'
        let regex = /^\<img.*?src=['"]?(blob|data):.*?\>/;
        let found = args.content.match(regex);
        if (found) {
            // Strip out the matching tag
            args.content = args.content.replace(regex, '');
            tinymce.activeEditor.notificationManager.open({
                type: 'warning',
                text: get_string_ajax('unabletopasteimage', 'mahara'),
            });
        }
    },
    fix_list_elements: true,
    image_advtab: true,
    table_style_by_css: true,
    quickbars_selection_toolbar: 'bold italic | formatselect | link unlink | bullist',
    // If you want to have image browser and quick table as default option at each new line,
    // uncomment the next line and set quick_bars_insert_toolbar: true,
    // quickbars_insert_toolbar: 'imagebrowser quicktable',
    quickbars_insert_toolbar: false,
    browser_spellcheck : true,
        block_formats: 'Paragraph=p; Heading 1=h4; Heading 2=h5; Heading 3=h6; Preformatted=pre',
        extended_valid_elements: extendedElements,
        urlconverter_callback: "custom_urlconvert",
        language: `fr_FR`,
        directionality: `ltr`,
        skin:  "oxide",
        skin: document.querySelector("html").getAttribute("data-bs-theme") == 'auto'
                && window.matchMedia("(prefers-color-scheme: dark)").matches
                && document.querySelector("html").getAttribute("data-theme") == 'raw'
                ? "oxide-dark" : "oxide",
        content_css:
                document.querySelector("html").getAttribute("data-bs-theme") == 'auto'
                && window.matchMedia("(prefers-color-scheme: dark)").matches
                && document.querySelector("html").getAttribute("data-theme") == 'raw'
                ? `https://eportfolio.univ-reims.fr/theme/ocean/style/tinymce.css?v=9359` : `https://eportfolio.univ-reims.fr/theme/ocean/style/tinymce.css?v=9359`, // Keep logic pattern for when fixing content_css in the future
                // ? 'dark' : 'dark',
        // content_style: "p { font-family: Open Sans; }",
        font_formats: fontFormats,
        remove_script_host: false,
        relative_urls: false,
        target_list: [
            { title: 'None', value: '' },
            // This one is not translated in tinymce lang files
            { title: `Même page` , value: '_self' },
            { title: 'New window', value: '_blank' }
        ],
        link_list: function (success) {
            // Only show the list of links in the normal user section
            if (1) {
                var params = {
                    'viewid': 50053
                }
                sendjsonrequest(config['wwwroot'] + 'json/tinymceviewlist.json.php', params, 'POST', function (data) {
                    if (data.count > 0) {
                        success(JSON.parse(data.data));
                    }
                    else {
                        success(''); // stop showing list with only option being 'none'
                    }
                });
            }
            else {
                success(''); // stop showing list with only option being 'none'
            }
        },
        'branding': false,
        cache_suffix: '?v=' + 9359,
        setup: function (ed) {
            
            // React to events: https://www.tiny.cloud/docs/tinymce/5/events/
            ed.on('init', function (ed) {
                
                if (typeof (editor_to_focus) == 'string' && ed.editorId == editor_to_focus) {
                    ed.trigger("focus");
                }
                // Set the initial height constraints.
                ed.target.settings.min_height = 100;
                ed.target.settings.max_height_limit = resizeLimit(ed.target);
                ed.target.settings.max_height = ed.target.settings.max_height_limit;
            });
            ed.on('keyup change', function (e) {
                checkTextareaMaxLength(ed.settings.id);
            });
            ed.on('LoadContent', function (e) {
                // Hide all the 2nd/3rd row menu buttons
                jQuery('.mce-toolbar.mce-first').siblings().addClass('d-none');
                // The tinymce fullscreen mode does not work properly in a transformed container div
                // such as div.vertcentre
                // and IE doesn't like a preset z-index
                // This work-around will remove/add classes: .vertcenter .configure .blockinstane
                // of the edit block div
                // when toggling fullscreen
                jQuery('div[aria-label="Fullscreen"]').on('click', function (e) {
                    jQuery('div#configureblock').toggleClass('vertcentre');
                    jQuery('div#configureblock').toggleClass('blockinstance');
                    jQuery('div#configureblock').toggleClass('configure');
                });
            });
            ed.on('ResizeEditor', function (e) {
                // Fired when the editor is resized, either by the resize
                // handles or the auto-resize plugin, or when fullscreen mode
                // is toggled.
                resizeCallback(ed.editorManager.activeEditor);
            });
            ed.on('ResizeWindow', function (e) {
                // This event can repeatedly trigger very rapidly when dragging
                // a window around manually; so we act on a timer after a brief
                // (for humans) delay, and ignore other instances of the event
                // entirely while that timer is running.
                let aed = ed.editorManager.activeEditor;
                let callback = function() {
                    aed.resizeTimer = null;
                    // Recalculate the upper limit based on the new window size.
                    aed.settings.max_height_limit = resizeLimit(aed);
                    // Update the editor max_height.
                    resizeCallback(aed);
                };
                if (!aed.resizeTimer) {
                    aed.resizeTimer = setTimeout(callback, 500);
                }
            });
            
        }
    }
    tinyMCE.init({...tinyMCEInitConfig, });

    function imageBrowserConfigSuccess(form, data) {
        // handle updates to file browser
        // final form submission handled by tinymce plugin
        if (data.formelementsuccess) {
            eval(data.formelementsuccess + '(form, data)');
            return;
        }
    }

    function imageBrowserConfigError(form, data) {
        if (data.formelementerror) {
            eval(data.formelementerror + '(form, data)');
            return;
        }
    }

    function custom_urlconvert(u, n, e) {
        // Don't convert the url on the skype status buttons.
        if (u.indexOf('skype:') == 0) {
            return u;
        }
        var t = tinyMCE.activeEditor, s = t.settings;

    // Don't convert link href since that's the CSS files that gets loaded into the editor also skip local file URLs
    if (!s.convert_urls || (e && e.nodeName == 'LINK') || u.indexOf('file:') === 0)
        return u;

    // Convert to relative
    if (s.relative_urls)
        return t.documentBaseURI.toRelative(u);

    // Convert to absolute
    u = t.documentBaseURI.toAbsolute(u, s.remove_script_host);

    return u;
}

</script>


